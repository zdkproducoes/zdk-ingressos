SUPABASE_SERVICE_ROLE_KEY=

# ===== Site =====
NEXT_PUBLIC_SITE_URL=https://SEUDOMINIO.com.br

# ===== Mercado Pago (mesma conta, aplicação NOVA da plataforma) =====
