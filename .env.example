NEXT_PUBLIC_PLATFORM_WHATSAPP=
# Dados jurídicos exibidos em termos/privacidade
NEXT_PUBLIC_LEGAL_NAME=ZDK PRODUÇÕES
NEXT_PUBLIC_LEGAL_DOCUMENT=
NEXT_PUBLIC_LEGAL_ADDRESS=
NEXT_PUBLIC_PRIVACY_EMAIL=privacidade@zdkproducoes.com.br
# Fatura do cartão no Mercado Pago (máx. 22 caracteres)
MP_STATEMENT_DESCRIPTOR=ZDKINGRESSOS
# Prefixo dos tokens de QR dos ingressos
TICKET_QR_PREFIX=ZDK-

# ===== Mercado Pago (mesma conta, aplicação NOVA da plataforma) =====
MP_ACCESS_TOKEN=
MP_PUBLIC_KEY=
MP_WEBHOOK_SECRET=

# ===== E-mail (Resend, domínio da plataforma verificado) =====
RESEND_API_KEY=
EMAIL_FROM=ZDK Ingressos <nao-responda@zdkingressos.com.br>

# ===== Cloudflare Turnstile (site novo) =====
